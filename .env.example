# Environment variables required in production (set these in the Vercel
# dashboard → Project → Settings → Environment Variables).
# Local dev keeps real values in gitignored env/dev.env instead.

# --- Required ---

# Neon connection string. Use the POOLED connection string (host contains
# "-pooler") for the app at runtime — serverless functions open many short
# connections. Example:
# postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# NextAuth session-encryption secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Public URL of the deployed app, used for OAuth callbacks + absolute links.
# e.g. https://worship-scheduler.vercel.app
NEXTAUTH_URL=

# Server timezone. Recurring set times are interpreted in this zone, so it
# MUST match your congregation's local time (serverless defaults to UTC).
TZ=America/Los_Angeles

# --- Optional OAuth providers (leave unset to disable) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
