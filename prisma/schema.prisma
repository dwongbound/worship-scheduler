// Worship Scheduler data model.
//
// The core hierarchy:
//   Set        — one worship set: a start time + duration.
//   Assignment — one person filling one slot (role) on a set's team.
//                The "team" is simply a set's list of assignments.
//   User       — a person; can play multiple instruments and may be admin.
//
// Slot capacities (4 vocals, 1 worship leader, 2 keys, ...) are business
// logic, not schema — see lib/constants.ts SLOT_CAPACITIES.

generator client {
  // Prisma 7: the Rust-free "prisma-client" generator with a required output.
  // Import from "@/lib/generated/prisma/client" (see lib/prisma.ts).
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Instruments double as both a user's skills and a team slot's role.
enum Instrument {
  WORSHIP_LEADER
  VOCALS // support vocals
  ACOUSTIC_GUITAR
  ELECTRIC_GUITAR
  KEYS // piano / keys
  STRINGS
  DRUMS
  BASS
}

// Lifecycle of an assignment:
//   PENDING        — auto-scheduled ("scheduled pending"), awaiting the
//                    user's manual confirmation.
//   CONFIRMED      — user accepted the set.
//   SWAP_REQUESTED — user wants out; visible to others with the same
//                    instrument until someone takes it (back to PENDING
//                    under the new user).
enum AssignmentStatus {
  PENDING
  CONFIRMED
  SWAP_REQUESTED
}

enum UnavailabilityType {
  RECURRING // "general block": every Tuesday morning (always applies)
  SPECIFIC // "specific block": one date + time window, tied to a request
  DATE_RANGE // legacy: "Jan 5 – Jan 10" (no longer created by the UI)
}

// One entry in a set's activity log (SetDetailModal's History section).
//   ADDED          — a slot was filled: the auto-scheduler (actor = null) or
//                    an admin (actor = that admin) put targetUser in role.
//   REMOVED        — an admin cleared a filled slot.
//   REASSIGNED     — an admin swapped previousUser out for targetUser.
//   CONFIRMED      — targetUser confirmed their own slot.
//   SWAP_REQUESTED — targetUser asked to be swapped out of their slot.
//   SWAP_CANCELED  — targetUser withdrew their own swap request.
//   SWAP_TAKEN     — targetUser took over previousUser's swap-requested slot.
enum SetHistoryEventType {
  ADDED
  REMOVED
  REASSIGNED
  CONFIRMED
  SWAP_REQUESTED
  SWAP_CANCELED
  SWAP_TAKEN
}

// An organization — the highest-level tenant boundary (e.g. one church).
// Orgs are declared in the ORG_KEYS env var ("Name:key,Name:key"); rows here
// are auto-upserted from it by name (lib/org.ts ensureOrgsSynced). Renaming
// an org in env therefore creates a NEW org — existing data stays under the
// old name until manually renamed in the db.
model Org {
  id   String @id @default(cuid())
  name String @unique

  // The key someone redeems to join this org. Moved off the ORG_KEYS env var
  // into the db so orgs + keys are managed in-app (platform admin page) with
  // no redeploy. Nullable during the env→db backfill; rotatable.
  joinKey String? @unique

  // Per-org Slack workspace install (Flow B). The bot token is encrypted at
  // rest (lib/crypto) — never store it plaintext. Null = Slack not connected
  // for this org (lib/slack falls back to the env token during transition).
  slackTeamId    String?
  slackTeamName  String?
  slackBotToken  String?
  slackBotUserId String?

  memberships          OrgMembership[]
  teams                Team[]
  sets                 Set[]
  templates            SetTemplate[]
  availabilityRequests AvailabilityRequest[]

  createdAt DateTime @default(now())

  @@map("orgs")
}

// A user's membership in one org, created by redeeming that org's key.
// Admin is PER-ORG: this flag replaces the old global User.isAdmin.
model OrgMembership {
  id      String  @id @default(cuid())
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
  org     Org     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId   String
  isAdmin Boolean @default(false)

  // This user's Slack member id (U…) IN THIS ORG's workspace. Member ids are
  // workspace-scoped, so the same person has a different one per org — hence
  // it lives here, per membership, rather than once on User.
  slackUserId String?

  createdAt DateTime @default(now())

  @@unique([userId, orgId])
  // A Slack member id is unique within its workspace (= one org).
  @@unique([orgId, slackUserId])
  @@map("org_memberships")
}

// A ministry team (e.g. "Sunday Team", "Prayer Room Team") within one org.
// Users belong to any number of teams; every set (and template) targets one
// team, and the auto-scheduler only proposes people who belong to it.
model Team {
  id   String @id @default(cuid())
  name String

  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId String

  // Slack channel (C...) the bot posts this team's set summaries to. The bot
  // must be invited to the channel; null = Slack summaries off for this team.
  slackChannelId String?

  users     User[]        @relation("TeamMembers")
  sets      Set[]
  templates SetTemplate[]

  createdAt DateTime @default(now())

  // Team names only need to be unique within their org.
  @@unique([orgId, name])
  @@map("teams")
}

model User {
  id           String  @id @default(cuid())
  username     String  @unique
  passwordHash String
  name         String
  email        String? @unique

  // Musical director: can be the designated MD on a set that requires one.
  // Note: isMD and instruments are global to the person, not per-org.
  isMD        Boolean      @default(false)
  instruments Instrument[] // which slots this user can fill
  // Orgs this person belongs to (admin is per-org — see OrgMembership).
  memberships OrgMembership[]
  // Teams this person serves on — only sets of these teams schedule them.
  teams       Team[]       @relation("TeamMembers")

  assignments           Assignment[]
  unavailability        Unavailability[]
  // One row per availability request the user has marked complete.
  availabilityResponses AvailabilityResponse[]

  // Set history: actions this user performed, was the subject of, or was
  // swapped/removed in favor of. See SetHistoryEvent for the relation roles.
  historyActed    SetHistoryEvent[] @relation("SetHistoryActor")
  historyTargeted SetHistoryEvent[] @relation("SetHistoryTarget")
  historyPrevious SetHistoryEvent[] @relation("SetHistoryPrevious")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// The smallest schedulable unit: a block of time needing a team.
model Set {
  id              String   @id @default(cuid())
  label           String? // e.g. "Sunday Morning Service"
  startsAt        DateTime
  durationMinutes Int
  notes           String? // free-form notes shown in the set detail modal

  // When true, this set needs at least one musical director (a User with
  // isMD) on its team; the scheduler tries to guarantee one.
  requiresMD Boolean @default(false)

  // Per-set team shape: an Instrument→count map (e.g. { ELECTRIC_GUITAR: 2,
  // ACOUSTIC_GUITAR: 0 }). Null = use the global SLOT_CAPACITIES default.
  // Copied from the SetTemplate at generate time; editable per ad-hoc set.
  slotCapacities Json?

  // The org this set belongs to — the tenant anchor even when teamId is null.
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId String

  // The team this set is for — only its members are auto-scheduled onto it.
  // Nullable so deleting a team orphans (not deletes) its sets; a null team
  // means "open to everyone in the org".
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)
  teamId String?

  assignments Assignment[]
  history     SetHistoryEvent[]

  createdAt DateTime @default(now())

  @@map("sets")
}

// One user filling one role slot on one set.
model Assignment {
  id     String           @id @default(cuid())
  set    Set              @relation(fields: [setId], references: [id], onDelete: Cascade)
  setId  String
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  role   Instrument
  status AssignmentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A person can hold several roles on one set (e.g. worship leader + acoustic
  // guitar) but never the same role twice.
  @@unique([setId, userId, role])
  @@map("assignments")
}

// One line in a set's activity log — see SetHistoryEventType for what each
// type means. Written alongside the assignment change it describes, never
// edited afterwards.
model SetHistoryEvent {
  id     String              @id @default(cuid())
  set    Set                 @relation(fields: [setId], references: [id], onDelete: Cascade)
  setId  String
  type   SetHistoryEventType
  role   Instrument

  // Who performed the action; null = the auto-scheduler (no human actor).
  actor   User?   @relation("SetHistoryActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorId String?

  // The person the slot belongs to after this event.
  targetUser   User?   @relation("SetHistoryTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetUserId String?

  // For REASSIGNED and SWAP_TAKEN: who held the slot immediately before.
  previousUser   User?   @relation("SetHistoryPrevious", fields: [previousUserId], references: [id], onDelete: SetNull)
  previousUserId String?

  createdAt DateTime @default(now())

  @@index([setId, createdAt])
  @@map("set_history_events")
}

// Times a user CANNOT serve. Three shapes share one table:
//   RECURRING : dayOfWeek + startMinute..endMinute (minutes from midnight)
//   SPECIFIC  : startDate (the day) + startMinute..endMinute, tied to a request
//   DATE_RANGE: startDate..endDate (inclusive) — legacy
model Unavailability {
  id     String             @id @default(cuid())
  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  type   UnavailabilityType

  // RECURRING fields — 0 = Sunday ... 6 = Saturday
  dayOfWeek   Int?
  // Time window (minutes from midnight) — RECURRING and SPECIFIC.
  startMinute Int?
  endMinute   Int?

  // SPECIFIC uses startDate as the single day; DATE_RANGE uses both.
  startDate DateTime?
  endDate   DateTime?

  // Set for SPECIFIC blocks (the TimeRange they belong to); null otherwise.
  request   AvailabilityRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId String?

  note String?

  createdAt DateTime @default(now())

  @@map("unavailability")
}

// Admin-defined weekly recurrence, e.g. "every Monday 19:00 for 60 min".
// The generate endpoint expands these into concrete Set rows.
model SetTemplate {
  id              String @id @default(cuid())
  label           String
  dayOfWeek       Int // 0 = Sunday ... 6 = Saturday
  startMinute     Int // minutes from midnight, e.g. 19:00 = 1140
  durationMinutes Int

  // Sets expanded from this template inherit this "needs an MD" flag.
  requiresMD Boolean @default(false)

  // The team shape this template's sets should have — see Set.slotCapacities.
  // Null = use the global SLOT_CAPACITIES default.
  slotCapacities Json?

  // The org this template (and its expanded sets) belongs to.
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId String

  // Sets expanded from this template belong to this team (see Set.team).
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)
  teamId String?

  createdAt DateTime @default(now())

  @@map("set_templates")
}

// An admin's request for the team to enter their availability over a date
// range. The most recent row PER ORG is that org's "active" request; a user
// owes a response for each of their orgs' active requests. Drives the
// Availabilities red dot + banner, and the Create tab's status panel.
model AvailabilityRequest {
  id        String   @id @default(cuid())
  // Optional admin-given name (e.g. "Fall 2026"); the UI falls back to the
  // date range when it's null.
  name      String?
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())

  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId String

  // Specific blocks entered against this request + who has marked it complete.
  unavailability Unavailability[]
  responses      AvailabilityResponse[]

  @@map("availability_requests")
}

// One row per (user, request) once the user hits "I'm done scheduling" for
// that request. Presence = complete; absence = still owes a response. Replaces
// the old global User.scheduleCompletedAt so completion is tracked per request.
model AvailabilityResponse {
  id        String              @id @default(cuid())
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  request   AvailabilityRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId String
  // null = the row exists but is currently marked "not submitted". The row
  // persists across un/re-submits so we can remember it was edited.
  completedAt DateTime?
  // True once re-submitted after having been un-submitted at least once.
  edited      Boolean           @default(false)

  @@unique([userId, requestId])
  @@map("availability_responses")
}
